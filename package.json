{
  "name": "@fluffylabs/pvm-interpreter-lite",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mateuszsikora/pvm-interpreter-lite"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "tsx --test $(find src -name '*.test.ts')",
    "build": "tsc && node build-cjs.js",
    "qa": "biome check src",
    "qa-fix": "biome check --write src"
  },
  "peerDependencies": {
    "@typeberry/lib": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tsconfig/node20": "^20.1.4",
    "@typeberry/lib": "latest",
    "@types/node": "^25.3.3",
    "esbuild": "^0.27.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
